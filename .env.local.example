# Auth — required in production (generate with: openssl rand -base64 32)
AUTH_SECRET=your_random_secret_at_least_32_chars

# Optional: SQLite database file path (default: ./data/seniorpath.db locally, /tmp on Vercel)
# DATABASE_PATH=./data/seniorpath.db

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key
